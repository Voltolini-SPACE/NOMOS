# Python
__pycache__/
*.py[cod]

# build/empacotamento (nunca versionar artefato)
build/
dist/
*.egg-info/
# sdist/build extraction dirs (ex.: nomos-1.3.0rc16/) — artefatos de build, nunca versionar
/nomos-[0-9]*/

# caches de ferramentas
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.cov*
htmlcov/

# ambientes
.venv/
venv*/

# dados locais do NOMOS (nunca versionar estado do usuário)
.nomos/
cerebros/
*.gguf

# macOS metadata
.DS_Store

# trava do loop (efêmera, nunca versionar)
loop/.lock
